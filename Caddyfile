{
	auto_https off
}

:{$PORT:5173} {
	root * {$STATIC_ROOT:frontend/dist}
	encode zstd gzip

	log {
		output stdout
		format console
	}

	@staticFiles path /assets/* /favicon.ico /env.js /brand/*
	handle @staticFiles {
		file_server
	}

	@sourceFiles path /src/* /node_modules/*
	handle @sourceFiles {
		respond "Not found" 404
	}

	handle {
		try_files {path} {path}/ /index.html
		file_server
	}
}
